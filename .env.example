# ============================================================
#  .env.example — Variáveis de Ambiente do Bot
# ============================================================
#  1. Copie este arquivo: cp .env.example .env
#  2. Preencha os valores abaixo
#  3. NUNCA commite o arquivo .env no Git
# ============================================================

# Número do WhatsApp que recebe notificações quando
# um usuário pede para falar com um consultor.
# Formato: DDI + DDD + número (apenas dígitos)
# Exemplo: 5511999990000  (Brasil +55, DDD 11, número)
ADMIN_WHATSAPP=5511999999900

# Modo de interface do menu
# false → menu em TEXTO numerado (WhatsApp pessoal - padrão e recomendado)
# true  → botões clicáveis reais (apenas WhatsApp Business API oficial)
MODO_BOTOES=false

# Ambiente de execução (development | production)
NODE_ENV=production







ADMIN_WHATSAPP=5581998191625

MODO_BOTOES=false

NODE_ENV=production
