# ============================================================
#  .env.example -- Variaveis de Ambiente do Bot
# ============================================================
#  1. Copie este arquivo: cp .env.example .env
#  2. Preencha os valores abaixo
#  3. NUNCA commite o arquivo .env no Git
# ============================================================

# Numero do WhatsApp que recebe notificacoes quando
# um usuario pede para falar com um consultor.
# Formato: DDI + DDD + numero (apenas digitos, sem + ou espacos)
# Exemplo: 5581999990000  (Brasil +55, DDD 81, numero 999990000)
ADMIN_WHATSAPP=5581999999999

# -- Modo de transporte -------------------------------------------
#
# false = Baileys / WhatsApp Web (PADRAO)
#         Conecta via QR code -- nao precisa de conta Business.
#
# true  = WhatsApp Business Cloud API (Meta)
#         Requer conta no Meta Business + variaveis WHATSAPP_CLOUD_* abaixo.
#
USE_CLOUD_API=false

# -- WhatsApp Business Cloud API (Meta) --------------------------
# Necessario apenas quando USE_CLOUD_API=true
#
# Como obter:
#  1. Acesse: https://developers.facebook.com/
#  2. Crie um App -> Tipo: Business
#  3. Adicione o produto "WhatsApp"
#  4. Em "API Setup" voce encontra o Phone Number ID e o token
#
# Token de acesso permanente da Meta Cloud API
WHATSAPP_CLOUD_TOKEN=EAAxxxxxxxxxxxxxxxxx

# ID do numero de telefone cadastrado no Meta
WHATSAPP_PHONE_NUMBER_ID=1234567890123456

# Token de verificacao do webhook (voce escolhe este valor)
# Deve ser identico ao configurado no painel Meta > Webhooks > Verify Token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=integra_bot_webhook

# Porta do servidor webhook (padrao 3000)
PORT=3000

# -- Modo de atendimento -----------------------------------------
#
# Define em quais tipos de chat o bot responde:
#
# privado = apenas mensagens diretas (PADRAO recomendado)
# grupo   = apenas grupos
# ambos   = mensagens diretas e grupos
#
MODO_ATENDIMENTO=privado

# -- Distribuicao automatica de leads (Round-Robin) ---------------
#
# Lista de consultores que recebem leads automaticamente.
# Separe com virgula, sem espacos.
# Formato: DDI+DDD+numero (apenas digitos)
# Exemplo: 5581999990001,5581999990002,5511999990003
#
# Se vazio, usa ADMIN_WHATSAPP como fallback (comportamento original).
#
CONSULTORES=

# -- Servidor de metricas -----------------------------------------
#
# Porta do endpoint GET /metrics (padrao: 4000)
# Uso: curl http://localhost:4000/metrics
#
METRICS_PORT=4000

# -- Google Sheets (opcional) ------------------------------------
#
# Para habilitar a integracao com Google Sheets:
#
# 1. Crie uma conta de servico em:
#    console.cloud.google.com > APIs & Services > Credentials
# 2. Ative a API "Google Sheets API"
# 3. Baixe o JSON da chave e copie client_email e private_key abaixo
# 4. Compartilhe a planilha com o client_email (permissao de Editor)
#
# ID da planilha (parte da URL: docs.google.com/spreadsheets/d/ESTE_ID/...)
GOOGLE_SHEETS_ID=

# Nome da aba onde os dados serao registrados (padrao: Leads)
GOOGLE_SHEETS_TAB=Leads

# Email da conta de servico (ex: bot@projeto.iam.gserviceaccount.com)
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Chave privada da conta de servico
# Cole o valor do campo "private_key" do JSON (com \n literais)
GOOGLE_PRIVATE_KEY=




atual 

ADMIN_WHATSAPP=5581998191625

USE_CLOUD_API=false

# privado = so mensagens diretas (padrao)
# grupo   = so grupos
# ambos   = privado + grupo
MODO_ATENDIMENTO=privado
