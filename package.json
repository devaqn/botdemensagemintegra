{
  "name": "integra-psicanalise-bot",
  "version": "2.0.0",
  "description": "Bot WhatsApp para suporte da Integra Psicanálise",
  "main": "index.js",
  "scripts": {
    "start":         "node index.js",
    "dev":           "node --watch index.js",
    "pm2:start":     "pm2 start ecosystem.config.js",
    "pm2:stop":      "pm2 stop integra-bot",
    "pm2:restart":   "pm2 restart integra-bot",
    "pm2:logs":      "pm2 logs integra-bot",
    "pm2:status":    "pm2 status",
    "pm2:save":      "pm2 save",
    "setup":         "npm install && cp -n .env.example .env || true"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.9",
    "dotenv": "^16.4.5",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "qrcode-terminal": "^0.12.0"
  },
  "author": "Integra Psicanálise",
  "license": "MIT"
}
